model Character {
    id            Int             @id @default(autoincrement())
    firstName     String
    lastName      String
    dob           DateTime        @default(now()) @db.Date
    gender        Gender
    idNumber      String          @db.Char(5)
    driverLicense DriverLicense?
    //age
    phoneNumber   String?
    address       String?
    hasGunPermit  Boolean         @default(false)
    flags         CharacterFlag[] @default([])
    userId        Int
    user          User            @relation(fields: [userId], references: [id])
    vehicles      Vehicle[]
}

enum Gender {
    MALE   @map("Male")
    FEMALE @map("Female")
}

enum CharacterFlag {
    MENTAL_HEALTH @map("Mental Health")
    BOLO
    WARRANT       @map("Warrant")
}
