model Character {
    id            Int             @id @default(autoincrement())
    name          String
    surname       String
    dob           DateTime        @default(now()) @db.Date
    gender        Gender
    driverLicense DriverLicense?
    //age
    phoneNumber   String?
    address       String?
    hasGunPermit  Boolean         @default(false)
    flags         CharacterFlag[] @default([])
    user          User            @relation(fields: [userId], references: [id])
    userId        Int
    vehicles      Vehicle[]
}

enum Gender {
    Male
    Female
}

enum CharacterFlag {
    MENTAL_HEALTH @map("Mental Health")
    BOLO
    WARRANT       @map("Warrant")
}
