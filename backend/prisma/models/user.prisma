model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  name          String
  password      String
  status        UserStatus     @default(PENDING)
  role          UserRole       @default(REGISTERED)
  createdAt     DateTime       @default(now())
  characters    Character[]
  refreshTokens RefreshToken[]
}

enum UserStatus {
  APPROVED
  REJECTED
  PENDING
  SUSPENDED
}

enum UserRole {
  REGISTERED
  POLICE
  DISPATCH
  EMS
  CIVILIAN
  ADMIN
}
