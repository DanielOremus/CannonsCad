<!DOCTYPE html>
<html>
  <head>
    <style>
      body {
        font-family: Arial, sans-serif;
        padding: 20px;
      }
      .container {
        padding: 30px;
        border-radius: 8px;
        max-width: 600px;
        margin: 0 auto;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h2>Welcome, <%= userName %>!</h2>
      <p>
        We're very glad to see you on our platform. Please verify your email by entering the code
        below during the next <strong><%= expiresIn %></strong>.
      </p>
      <h3><%= code %></h3>
      <p>If you didn't create account, you can ignore this email.</p>
    </div>
  </body>
</html>
