{
  "name": "@project/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "dotenv -e .env.test -- vitest run",
    "start": "node dist/bin/www.js",
    "build": "npm run clean && tsc && npm run copyfiles",
    "clean": "rimraf dist/",
    "copyfiles": "copyfiles -u 1 src/**/*.ejs src/**/*.css dist/",
    "dev": "npm run build && cross-env DEBUG=app:backend dotenv -e .env nodemon dist/bin/www.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@project/shared": "*",
    "bcrypt": "^6.0.0",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^17.4.2",
    "ejs": "~2.6.1",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "~1.9.1",
    "pg": "^8.21.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
